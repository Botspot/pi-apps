#!/bin/bash

# App ID
ID='com.thebrokenrail.MCPIReborn'
OLD_ID="${ID}Client"

# Uninstall
BIN="${HOME}/.local/bin"
APPIMAGE="${BIN}/${ID}.AppImage"
if [ -f "${APPIMAGE}" ]; then
    "${APPIMAGE}" --uninstall-desktop-entry
fi
rm -f "${APPIMAGE}"

# Cleanup Old Versions
rm -f "${HOME}/.local/share/applications/${OLD_ID}.desktop"
rm -f "${BIN}/${OLD_ID}.AppImage"

#remove old and unused apt repo and keyring which caused problems for a user https://github.com/Botspot/pi-apps/issues/2927#issuecomment-4119171159
sudo rm -f /etc/apt/sources.list.d/minecraft-pi-reborn.list /etc/apt/keyrings/minecraft-pi-reborn.asc
